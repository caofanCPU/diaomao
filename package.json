{
  "name": "@windrun-huaiin/diaomao",
  "version": "29.0.0",
  "private": false,
  "packageManager": "pnpm@10.33.2",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "keywords": [
    "fumadocs",
    "clerk",
    "nextjs",
    "template",
    "diaomao",
    "react"
  ],
  "scripts": {
    "dev": "turbo run task:dev",
    "md:build": "turbo run task:md:build",
    "build": "turbo run task:build",
    "build:dev": "turbo run task:build:dev",
    "build:prod": "turbo run task:build:prod",
    "task:dev": "prisma generate && next dev",
    "task:md:build": "pnpm exec local-md build",
    "task:build": "pnpm generate-blog-index && prisma generate && next build",
    "task:build:dev": "pnpm generate-blog-index && prisma generate && next build",
    "task:build:prod": "prisma generate && next build",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "deep-clean": "dev-scripts deep-clean",
    "d8": "pnpm run deep-clean",
    "diaomao-help": "dev-scripts -h",
    "diaomao-update": "pnpm add -D @windrun-huaiin/dev-scripts@latest && pnpm exec dev-scripts diaomao-update -v",
    "easy-changeset": "dev-scripts easy-changeset",
    "dj": "pnpm run easy-changeset && pnpm changeset status",
    "djv": "pnpm changeset version",
    "djvp": "pnpm changeset publish",
    "generate-blog-index": "dev-scripts generate-blog-index -v",
    "i18n": "dev-scripts check-translations -v",
    "core-list-route": "dev-scripts backend-core routes:list",
    "core-sync-route": "dev-scripts backend-core routes:sync",
    "whoareyou": "dev-scripts generate-nextjs-architecture -v"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.0.5",
    "@types/mdx": "^2.0.13",
    "@windrun-huaiin/backend-core": "29.0.1",
    "@windrun-huaiin/base-ui": "29.0.0",
    "@windrun-huaiin/contracts": "29.0.0",
    "@windrun-huaiin/fumadocs-local-md": "29.0.0",
    "@windrun-huaiin/lib": "29.0.0",
    "@windrun-huaiin/third-ui": "29.0.2",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0",
    "turbo": "^2.9.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@prisma/client": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/hast": "^3.0.4",
    "@types/node": "^25.3.2",
    "@types/nprogress": "^0.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.56.1",
    "@windrun-huaiin/dev-scripts": "^29.0.1",
    "dotenv": "^17.4.2",
    "baseline-browser-mapping": "^2.10.0",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.1.6",
    "eslint-plugin-unused-imports": "^4.4.1",
    "nprogress": "^0.2.0",
    "postcss": "^8.5.6",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@clerk/shared",
      "@parcel/watcher",
      "@prisma/client",
      "@prisma/engines",
      "@swc/core",
      "@tailwindcss/oxide",
      "core-js",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  },
  "files": [
    ".changeset",
    "!.changeset/d8-template.mdx",
    "patches",
    "src",
    "public",
    ".gitignore",
    "messages",
    ".env.local.txt",
    "eslint.config.js",
    "components.json",
    "dev-scripts.config.json",
    "LICENSE",
    "next-env.d.ts",
    "next.config.ts",
    "postcss.config.mjs",
    "tailwind.config.ts",
    "source.config.ts",
    "tsconfig.json",
    "tsconfig.node.json",
    "!**/scripts/**",
    "!**/*.test.{js,ts}",
    "!**/*.log"
  ]
}
