{
  "name": "@windrun-huaiin/diaomao",
  "version": "26.0.0",
  "private": false,
  "packageManager": "pnpm@10.33.2",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "keywords": [
    "fumadocs",
    "clerk",
    "nextjs",
    "template",
    "diaomao",
    "react"
  ],
  "scripts": {
    "dev": "turbo run task:dev",
    "md:build": "turbo run task:md:build",
    "build": "turbo run task:build",
    "build:dev": "turbo run task:build:dev",
    "build:prod": "turbo run task:build:prod",
    "task:dev": "prisma generate && next dev",
    "task:md:build": "pnpm exec local-md build",
    "task:build": "pnpm generate-blog-index && prisma generate && next build",
    "task:build:dev": "pnpm generate-blog-index && prisma generate && next build",
    "task:build:prod": "prisma generate && next build",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "deep-clean": "dev-scripts deep-clean",
    "d8": "pnpm run deep-clean",
    "diaomao-help": "dev-scripts -h",
    "diaomao-update": "pnpm add -D @windrun-huaiin/dev-scripts@latest && pnpm exec dev-scripts diaomao-update -v",
    "easy-changeset": "dev-scripts easy-changeset",
    "dj": "pnpm run easy-changeset && pnpm changeset status",
    "djv": "pnpm changeset version",
    "djvp": "pnpm changeset publish",
    "generate-blog-index": "dev-scripts generate-blog-index -v",
    "i18n": "dev-scripts check-translations -v",
    "core-list-route": "dev-scripts backend-core routes:list",
    "core-sync-route": "dev-scripts backend-core routes:sync",
    "whoareyou": "dev-scripts generate-nextjs-architecture -v"
  },
  "dependencies": {
    "@clerk/localizations": "^4.2.2",
    "@clerk/nextjs": "^7.0.5",
    "@clerk/shared": "^4.3.1",
    "@clerk/themes": "^2.4.57",
    "@fingerprintjs/fingerprintjs": "^5.1.0",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/mdx": "^2.0.13",
    "@windrun-huaiin/backend-core": "28.0.1",
    "@windrun-huaiin/base-ui": "28.0.0",
    "@windrun-huaiin/contracts": "22.0.0",
    "@windrun-huaiin/fumadocs-local-md": "28.0.0",
    "@windrun-huaiin/lib": "28.0.0",
    "@windrun-huaiin/third-ui": "28.0.0",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "fumadocs-core": "16.8.2",
    "fumadocs-ui": "16.8.2",
    "katex": "^0.16.33",
    "lucide-react": "^0.577.0",
    "mermaid": "11.12.1",
    "next": "16.1.6",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-medium-image-zoom": "^5.4.1",
    "rehype-katex": "^7.0.1",
    "remark": "^15.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-mdx": "^3.1.1",
    "shiki": "^4.0.0",
    "stripe": "22.0.2",
    "svix": "^1.86.0",
    "swiper": "^12.1.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "turbo": "^2.9.6",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@prisma/client": "^6.19.0",
    "@tailwindcss/cli": "^4.2.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/hast": "^3.0.4",
    "@types/node": "^25.3.2",
    "@types/nprogress": "^0.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.56.1",
    "@windrun-huaiin/dev-scripts": "^28.0.1",
    "baseline-browser-mapping": "^2.10.0",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.1.6",
    "eslint-plugin-unused-imports": "^4.4.1",
    "fast-glob": "^3.3.3",
    "nprogress": "^0.2.0",
    "postcss": "^8.5.6",
    "prisma": "^6.19.0",
    "tailwindcss": "^4.2.1",
    "ts-morph": "^27.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "unist-util-visit": "^5.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@clerk/shared",
      "@parcel/watcher",
      "@prisma/client",
      "@prisma/engines",
      "@swc/core",
      "@tailwindcss/oxide",
      "core-js",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  },
  "files": [
    ".changeset",
    "!.changeset/d8-template.mdx",
    "patches",
    "src",
    "public",
    ".gitignore",
    "messages",
    ".env.local.txt",
    "eslint.config.js",
    "components.json",
    "dev-scripts.config.json",
    "LICENSE",
    "next-env.d.ts",
    "next.config.ts",
    "postcss.config.mjs",
    "tailwind.config.ts",
    "source.config.ts",
    "tsconfig.json",
    "tsconfig.node.json",
    "!**/scripts/**",
    "!**/*.test.{js,ts}",
    "!**/*.log"
  ]
}
