{
  "$schema": "https://v2-9-6.turborepo.dev/schema.json",
  "globalEnv": [
    "NODE_ENV",
    "TURBO_TELEMETRY_DISABLED",
    "TURBO_TOKEN",
    "TURBO_TEAM"
  ],
  "tasks": {
    "app:build": {
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "NODE_ENV",
        "LOCAL_MD_*",
        "NEXT_PUBLIC_*",
        "CLERK_SECRET_KEY",
        "CLERK_DEBUG",
        "NEXT_PUBLIC_CLERK_*",
        "DATABASE_URL",
        "CLERK_WEBHOOK_SECRET",
        "ENABLE_STRIPE_SUBSCRIPTION_UPGRADE",
        "SHOW_FINGERPRINT_STATUS",
        "ACTIVE_PAYMENT_PROVIDER",
        "OPENROUTER_*",
        "MONEY_PRICE_*",
        "CREDITS_*",
        "STRIPE_*",
        "UPSTASH_REDIS_*",
        "QSTASH_*"
      ]
    },
    "app:build:dev": {
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "NODE_ENV",
        "LOCAL_MD_*",
        "NEXT_PUBLIC_*",
        "CLERK_SECRET_KEY",
        "CLERK_DEBUG",
        "NEXT_PUBLIC_CLERK_*",
        "DATABASE_URL",
        "CLERK_WEBHOOK_SECRET",
        "ENABLE_STRIPE_SUBSCRIPTION_UPGRADE",
        "SHOW_FINGERPRINT_STATUS",
        "ACTIVE_PAYMENT_PROVIDER",
        "OPENROUTER_*",
        "MONEY_PRICE_*",
        "CREDITS_*",
        "STRIPE_*",
        "UPSTASH_REDIS_*",
        "QSTASH_*"
      ]
    },
    "app:build:prod": {
      "dependsOn": ["app:md-build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "NODE_ENV",
        "LOCAL_MD_*",
        "NEXT_PUBLIC_*",
        "CLERK_SECRET_KEY",
        "CLERK_DEBUG",
        "NEXT_PUBLIC_CLERK_*",
        "DATABASE_URL",
        "CLERK_WEBHOOK_SECRET",
        "ENABLE_STRIPE_SUBSCRIPTION_UPGRADE",
        "SHOW_FINGERPRINT_STATUS",
        "ACTIVE_PAYMENT_PROVIDER",
        "OPENROUTER_*",
        "MONEY_PRICE_*",
        "CREDITS_*",
        "STRIPE_*",
        "UPSTASH_REDIS_*",
        "QSTASH_*"
      ]
    },
    "app:md-build": {
      "inputs": [
        "src/mdx/**",
        "messages/**",
        "src/lib/site-docs*.ts",
        "src/lib/i18n-base.ts",
        "dev-scripts.config.json",
        "package.json"
      ],
      "outputs": [".source/**"],
      "env": [
        "NODE_ENV",
        "LOCAL_MD_*",
        "NEXT_PUBLIC_*"
      ]
    },
    "app:dev": {
      "cache": false,
      "persistent": true,
      "env": [
        "NODE_ENV",
        "LOCAL_MD_*",
        "NEXT_PUBLIC_*",
        "CLERK_SECRET_KEY",
        "CLERK_DEBUG",
        "DATABASE_URL",
        "CLERK_WEBHOOK_SECRET",
        "ENABLE_STRIPE_SUBSCRIPTION_UPGRADE",
        "SHOW_FINGERPRINT_STATUS",
        "ACTIVE_PAYMENT_PROVIDER",
        "OPENROUTER_*",
        "MONEY_PRICE_*",
        "CREDITS_*",
        "STRIPE_*",
        "UPSTASH_REDIS_*",
        "QSTASH_*"
      ]
    },
    "lint": {
      "outputs": [],
      "env": ["NODE_ENV"]
    }
  }
}
